# Frontend / Admin (Vercel env vars)
NEXT_PUBLIC_API_URL=https://api.foodstudio.vn/v1

# Backend local dev (.dev.vars — never commit)
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
VNPAY_SECRET=your_vnpay_secret
VNPAY_TMN_CODE=your_vnpay_tmn_code
MOMO_KEY=your_momo_key
MOMO_SECRET=your_momo_secret
ZALOPAY_KEY=your_zalopay_key
SENDGRID_KEY=your_sendgrid_api_key
GHN_TOKEN=your_ghn_api_token
GHTK_TOKEN=your_ghtk_api_token
SENTRY_DSN=your_sentry_dsn
